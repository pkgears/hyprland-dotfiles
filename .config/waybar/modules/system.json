{
  "hyprland/workspaces": {
    "disable-scroll": true,
    "all-outputs": true,
    "format": "{name}"
  },
  "hyprland/language": {
    "format": "⌨️ {short}",
    "min-length": 5
  },
  "cpu": {
    "format": "  {usage}%",
    "tooltip": false,
    "on-click": "eww close sysboard || eww open sysboard"
  },
  "memory": {
    "format": "󰘚  {}%",
    "on-click": "eww close sysboard || eww open sysboard"
  },
  "clock": {
    "format": "{:%H:%M  |  %a %d/%m}",
    "tooltip": false,
    "on-click": "~/.config/eww/scripts/launch_calendar.sh"
  }
}